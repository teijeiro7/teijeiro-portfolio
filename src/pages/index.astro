---
import Layout from "../layouts/Layout.astro";
import Nav from "./components/nav.astro";
import Projects from "./components/projects.astro";
import Work from "../components/Work.astro";
import Contact from "./components/contact.astro";
---

<Layout title="Cristian Teijeiro | Software Engineer Portfolio">
  <Nav />

  <main id="top">
    <!-- ================= HERO ================= -->
    <section class="hero">
      <div class="container">
        <div class="hero-top reveal">
          <span class="kicker">
            <span class="num">01</span>
            <span data-i18="hero.kicker">· Software Engineer · Madrid</span>
          </span>
        </div>
        <div class="reveal">
          <h1 class="display">
            Cristian<br />
            Teijeiro<span class="period">.</span>
          </h1>
          <p class="lead" data-i18="hero.lead">
            I build digital products with AI and clean architecture. From idea
            to deploy, one commit at a time.
          </p>
          <div class="hero-meta">
            <span class="pill"
              ><span class="dot" aria-hidden="true"></span><span
                data-i18="hero.pillRole">Software Engineer</span
              ></span
            >
            <span class="pill"
              ><span data-i18="hero.pillCompany">@ Fusuma</span></span
            >
            <span class="pill"
              ><span data-i18="hero.pillDegree">URJC · Graduated</span></span
            >
            <span class="pill">ES · EN</span>
          </div>
          <div class="hero-cta">
            <a href="#projects" class="btn btn-primary">
              <span data-i18="hero.ctaProjects">See projects</span>
              <span class="arr" aria-hidden="true">→</span>
            </a>
            <a href="#contact" class="btn">
              <span data-i18="hero.ctaContact">Get in touch</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <Projects />
    <Work />
    <Contact />
  </main>
</Layout>

<style>
  .hero {
    padding-block: 56px 96px;
  }
  @media (max-width: 720px) {
    .hero {
      padding-block: 40px 48px;
    }
  }
  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--accent);
    margin-bottom: 48px;
  }
  .hero h1 {
    letter-spacing: -0.045em;
  }
  .hero h1 .period {
    color: var(--accent);
  }
  .hero .lead {
    margin-top: 32px;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 32px;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 40px;
  }

  @media (max-width: 720px) {
    .hero-top {
      padding-bottom: 24px;
      margin-bottom: 32px;
    }
  }
</style>
