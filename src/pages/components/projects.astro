---
const githubIconPath =
  "M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.06 11.06 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z";
---

<section class="section" id="projects">
  <div class="container">
    <header class="section-head reveal">
      <div>
        <span class="kicker"
          ><span class="num">02</span> · <span data-i18="projects.kicker"
            >Projects</span
          ></span
        >
        <h2 class="h2 title" style="margin-top: 8px;" data-i18="projects.title">
          Things I keep shipping.
        </h2>
      </div>
      <a
        class="meta"
        href="https://github.com/teijeiro7"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span data-i18="projects.viewAll">All on GitHub</span> →
      </a>
    </header>

    <div class="project-grid">
      <article class="project featured reveal">
        <div class="project-thumb">
          <span class="project-thumb-tag" data-i18="projects.featured"
            >Featured</span
          >
          <img
            class="project-thumb-img"
            src="/images/orial-app.png"
            alt="Orial app icon"
            style="object-position: center;"
          />
          <span class="project-thumb-label">Orial · React Native</span>
        </div>
        <h3 class="project-name">Orial</h3>
        <p class="project-desc" data-i18="projects.orialDesc">
          A mobile habit tracker — streak logic, activity history, and data
          analysis. Local-first with expo-sqlite, typed with Drizzle, file-based
          routing via Expo Router.
        </p>
        <div class="project-stack">
          <span class="chip">React Native</span>
          <span class="chip">Expo</span>
          <span class="chip">TypeScript</span>
          <span class="chip">Drizzle</span>
          <span class="chip">SQLite</span>
        </div>
        <div class="project-foot">
          <a
            class="project-link"
            href="https://github.com/teijeiro7/orial"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path d={githubIconPath}></path></svg
            >
            <span data-i18="projects.source">Source</span>
          </a>
        </div>
      </article>

      <article class="project reveal">
        <div class="project-thumb">
          <img
            class="project-thumb-img"
            src="/images/smashly.png"
            alt="Smashly app screenshot"
          />
          <span class="project-thumb-label">Smashly · Web</span>
        </div>
        <h3 class="project-name">Smashly</h3>
        <p class="project-desc" data-i18="projects.smashlyDesc">
          Padel racket matcher — find your ideal racket, compare against
          alternatives. React + Vite + Supabase, with a small Python service for
          natural-language reviews.
        </p>
        <div class="project-stack">
          <span class="chip">React</span>
          <span class="chip">Vite</span>
          <span class="chip">Supabase</span>
          <span class="chip">Python</span>
          <span class="chip chip-accent">AI</span>
        </div>
        <div class="project-foot">
          <a
            class="project-link"
            href="https://github.com/codeurjc-students/2025-Smashlyapp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path d={githubIconPath}></path></svg
            >
            <span data-i18="projects.source">Source</span>
          </a>
        </div>
      </article>

      <article class="project reveal">
        <div class="project-thumb">
          <div class="glyph">F</div>
          <span class="project-thumb-label">Free-AI-API · Edge</span>
        </div>
        <h3 class="project-name">Free-AI-API</h3>
        <p class="project-desc" data-i18="projects.freeaiDesc">
          Cloudflare Workers gateway that fronts multiple free-tier LLM
          providers behind one OpenAI-compatible endpoint. Swap providers
          without rewriting client code.
        </p>
        <div class="project-stack">
          <span class="chip">Cloudflare</span>
          <span class="chip">Workers</span>
          <span class="chip">TypeScript</span>
        </div>
        <div class="project-foot">
          <a
            class="project-link"
            href="https://github.com/teijeiro7"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path d={githubIconPath}></path></svg
            >
            <span data-i18="projects.source">Source</span>
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 720px) {
    .project-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1000px) {
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project {
    display: flex;
    flex-direction: column;
    padding: 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    border-radius: var(--radius);
    transition:
      border-color 0.15s,
      transform 0.15s;
  }
  .project:hover {
    border-color: var(--fg);
    border-top-color: var(--accent);
  }
  .project.featured {
    background: var(--surface);
  }
  .project-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: grid;
    place-items: center;
    margin-bottom: 16px;
    overflow: hidden;
    position: relative;
  }
  .project.featured .project-thumb {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  .project-thumb-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 3px 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--accent);
    color: #ffffff;
    border-radius: 999px;
  }
  .project-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .project-thumb-label {
    position: absolute;
    bottom: 10px;
    left: 10px;
    padding: 3px 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #ffffff;
    background: color-mix(in oklch, #000000 55%, transparent);
    border-radius: 999px;
  }
  .project-thumb .glyph {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: clamp(56px, 8vw, 96px);
    letter-spacing: -0.05em;
    line-height: 1;
  }
  .project-name {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .project-desc {
    margin-top: 6px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }
  .project-stack .chip {
    padding: 3px 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .project.featured .project-stack .chip {
    background: var(--bg);
  }
  .chip.chip-accent {
    color: var(--accent);
    border-color: var(--accent);
  }
  .project-foot {
    display: flex;
    gap: 12px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg);
  }
  .project-link:hover {
    color: var(--accent);
  }
  .project-link svg {
    width: 12px;
    height: 12px;
  }
</style>
