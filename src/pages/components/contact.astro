---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="reveal">
        <span class="kicker"
          ><span class="num">04</span> · <span data-i18="contact.kicker"
            >Contact</span
          ></span
        >
        <h2 style="margin-top: 8px;" data-i18="contact.titleLine1">Say</h2>
        <h2 style="margin-top: 0;">
          <em data-i18="contact.titleLine2">hi</em><span
            class="period"
            style="color: var(--accent);">.</span
          >
        </h2>
        <p class="lead" data-i18="contact.lead">
          Open to interesting projects and good teams.
        </p>
        <div class="email-row">
          <span class="v" id="email-value">teijeiroparga@outlook.com</span>
          <button
            class="copy-btn"
            type="button"
            id="copy-email"
            aria-label="Copy email"
          >
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"
              ></rect><path
                d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
              ></path></svg
            >
            <span class="copy-text" data-i18="contact.copy">Copy</span>
          </button>
        </div>
        <dl class="contact-info">
          <dt data-i18="contact.based">Based</dt>
          <dd data-i18="contact.basedVal">Madrid, Spain</dd>
          <dt data-i18="contact.remote">Remote</dt>
          <dd data-i18="contact.remoteVal">Yes · relocation open</dd>
        </dl>
        <div class="socials">
          <a
            href="https://github.com/teijeiro7"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.06 11.06 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
              ></path></svg
            >
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/cristianteijeiroparga/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"
              ></path></svg
            >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>

  <footer class="pagefoot">
    <div class="container pagefoot-inner">
      <span>© 2026 Cristian Teijeiro</span>
      <a href="#top">
        <span data-i18="footer.top">Top</span> ↑
      </a>
    </div>
  </footer>
</section>

<style>
  .contact {
    padding-block: 96px;
    border-top: 1px solid var(--accent);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .contact h2 {
    font-weight: 200;
    font-size: clamp(40px, 6vw, 88px);
    letter-spacing: -0.04em;
  }
  .contact h2 em {
    font-style: normal;
    font-weight: 700;
  }
  .contact .lead {
    margin-top: 16px;
  }
  .email-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  html.dark .email-row {
    background: color-mix(in oklch, #ffffff 8%, #000000);
    border-color: color-mix(in oklch, #ffffff 22%, #000000);
  }
  .email-row .v {
    flex: 1;
  }
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
  }
  .copy-btn:hover {
    border-color: var(--fg);
  }
  .copy-btn.copied {
    color: var(--accent);
    border-color: var(--accent);
  }
  html.dark .copy-btn {
    background: color-mix(in oklch, #ffffff 4%, #000000);
    border-color: color-mix(in oklch, #ffffff 22%, #000000);
  }

  .contact-info {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 16px;
    margin: 24px 0 0;
    font-size: 14px;
  }
  .contact-info dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding-top: 3px;
  }
  .contact-info dd {
    margin: 0;
  }
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 24px;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .socials a:hover {
    border-color: var(--fg);
  }
  .socials svg {
    width: 12px;
    height: 12px;
  }

  .pagefoot {
    padding-block: 32px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    margin-top: 96px;
  }
  .pagefoot-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .pagefoot a {
    color: var(--fg);
  }
  .pagefoot a:hover {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .contact {
      padding-block: 64px;
    }
    .pagefoot {
      margin-top: 64px;
    }
  }
</style>

<script>
  import { translations, type Language } from "../../i18n/translations";

  const btn = document.getElementById("copy-email") as HTMLButtonElement | null;
  const email = document.getElementById("email-value");

  btn?.addEventListener("click", async () => {
    const v = email?.textContent?.trim();
    if (!v) return;
    const lang = (localStorage.getItem("language") as Language) || "en";
    const label = btn.querySelector(".copy-text") as HTMLSpanElement | null;

    try {
      await navigator.clipboard.writeText(v);
    } catch {
      const x = document.createElement("textarea");
      x.value = v;
      x.style.position = "fixed";
      x.style.opacity = "0";
      document.body.appendChild(x);
      x.select();
      document.execCommand("copy");
      document.body.removeChild(x);
    }

    btn.classList.add("copied");
    if (label) label.textContent = translations[lang].contact.copied;
    setTimeout(() => {
      btn.classList.remove("copied");
      if (label) label.textContent = translations[lang].contact.copy;
    }, 1600);
  });
</script>
