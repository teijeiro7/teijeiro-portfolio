---
---

<section class="contact-section" id="contact">
  <div class="container">
    <!-- Decorative background elements -->
    <div class="bg-decorations">
      <div class="bg-circle bg-circle-1"></div>
      <div class="bg-circle bg-circle-2"></div>
      <div class="bg-grid"></div>
    </div>

    <div class="contact-grid">
      <!-- Left Column: Info + Contact Methods -->
      <div class="contact-info">
        <div class="section-header">
          <div class="section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="badge-text" data-i18="contact.badge">Get in Touch</span>
          </div>
          <h2 class="section-title" data-i18="contact.title">Let's Work Together</h2>
          <p class="section-description" data-i18="contact.description">
            I'm always interested in new opportunities and exciting projects. Whether you have a question or just want to say hi, feel free to reach out!
          </p>
        </div>

        <div class="contact-methods">
          <div class="contact-method">
            <div class="method-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--accent)" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect>
                <polyline points="22,4 12,13 2,4" stroke="white" fill="none"></polyline>
              </svg>
            </div>
            <div class="method-content">
              <div class="method-label" data-i18="contact.emailLabel">Email</div>
              <div class="method-value">teijeiroparga@outlook.com</div>
              <button
                class="copy-btn"
                data-email="teijeiroparga@outlook.com"
                data-i18-btn="contact.copyEmail"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="copy-text">Copy Email</span>
              </button>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--accent)" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3" fill="white" stroke="none"></circle>
              </svg>
            </div>
            <div class="method-content">
              <div class="method-label" data-i18="contact.locationLabel">Location</div>
              <div class="method-value" data-i18="hero.location">Madrid, Spain</div>
              <div class="method-tag" data-i18="contact.availableRemote">Open to remote · Available for relocation</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Quick Connect -->
      <div class="connect-section">
        <div class="connect-card">
          <div class="connect-header">
            <h3 class="connect-title">Quick Connect</h3>
            <p class="connect-subtitle">Let's start a conversation</p>
          </div>

          <div class="connect-cta">
            <a href="mailto:teijeiroparga@outlook.com" class="cta-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              Send an Email
            </a>
          </div>

          <div class="connect-divider">
            <span class="divider-text">or find me on</span>
          </div>

          <div class="connect-social">
            <a
              href="https://github.com/teijeiro7"
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
              aria-label="GitHub"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
              </svg>
              <span class="social-btn-label">GitHub</span>
            </a>
            <a
              href="https://www.linkedin.com/in/cristianteijeiroparga/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
              aria-label="LinkedIn"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
              </svg>
              <span class="social-btn-label">LinkedIn</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 0;
    background: var(--primary);
    position: relative;
    overflow: hidden;
  }

  /* === Background Decorations === */
  .bg-decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.03;
  }

  .bg-circle-1 {
    width: 500px;
    height: 500px;
    background: var(--accent);
    top: -200px;
    right: -150px;
    filter: blur(80px);
  }

  .bg-circle-2 {
    width: 400px;
    height: 400px;
    background: var(--accent);
    bottom: -150px;
    left: -100px;
    filter: blur(80px);
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(220, 38, 38, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(220, 38, 38, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
    position: relative;
    z-index: 1;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  /* === Left Column === */
  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.15);
    border-radius: 9999px;
    margin-bottom: var(--space-md);
    color: var(--accent);
  }

  .badge-text {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: var(--space-sm);
    line-height: 1.15;
    letter-spacing: -0.02em;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-description {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-method {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-md);
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }

  .contact-method:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(220, 38, 38, 0.08);
    transform: translateY(-2px);
  }

  .method-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    min-width: 46px;
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.15);
    border-radius: var(--radius-md);
    color: var(--accent);
  }

  .method-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .method-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--accent);
  }

  .method-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: inherit;
    width: fit-content;
  }

  .copy-btn:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  .method-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.78rem;
    color: var(--accent);
    font-weight: 500;
    margin-top: 2px;
  }

  .method-tag::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    min-width: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* === Right Column === */
  .connect-section {
    display: flex;
    justify-content: center;
  }

  .connect-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    width: 100%;
    max-width: 380px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .connect-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
  }

  .connect-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 30px rgba(220, 38, 38, 0.1);
    transform: translateY(-4px);
  }

  .connect-header {
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .connect-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .connect-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .connect-cta {
    margin-bottom: var(--space-lg);
  }

  .cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 24px;
    background: var(--accent-gradient);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
    font-family: inherit;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(220, 38, 38, 0.4);
  }

  .cta-btn:active {
    transform: translateY(0);
  }

  .connect-divider {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .connect-divider::before,
  .connect-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .divider-text {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
    font-weight: 500;
  }

  .connect-social {
    display: flex;
    gap: var(--space-sm);
  }

  .social-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.25s ease;
  }

  .social-btn:hover {
    background: var(--hover-bg);
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .social-btn svg {
    width: 20px;
    height: 20px;
    transition: transform 0.25s ease;
  }

  .social-btn:hover svg {
    transform: scale(1.1);
  }

  .social-btn-label {
    font-size: 0.85rem;
  }

  /* === Responsive === */
  @media (max-width: 1024px) {
    .contact-section {
      padding: 5rem 0;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .section-description {
      max-width: 100%;
    }

    .connect-card {
      max-width: 100%;
    }

    .connect-section {
      justify-content: stretch;
    }
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: clamp(1.75rem, 5vw, 2.5rem);
    }

    .section-description {
      font-size: 1rem;
    }

    .contact-method {
      padding: var(--space-sm);
    }

    .connect-card {
      padding: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .contact-section {
      padding: 3rem 0;
    }

    .container {
      padding: 0 var(--space-sm);
    }

    .section-badge {
      padding: 4px 12px;
    }

    .badge-text {
      font-size: 0.75rem;
    }

    .method-icon {
      width: 40px;
      height: 40px;
      min-width: 40px;
    }

    .method-icon svg {
      width: 18px;
      height: 18px;
    }

    .connect-card {
      padding: var(--space-md);
    }

    .connect-social {
      flex-direction: column;
    }

    .social-btn {
      padding: 10px 14px;
    }
  }
</style>

<script>
  type Language = 'es' | 'en';

  const translations = {
    es: {
      copyEmail: 'Copiar Email',
      copied: '¡Copiado!',
    },
    en: {
      copyEmail: 'Copy Email',
      copied: 'Copied!',
    },
  };

  function getTranslation(key: string, lang: Language): string {
    const keys = key.split('.');
    let value: any = translations[lang];
    for (const k of keys) {
      value = value?.[k];
    }
    return value || key;
  }

  function updateContactTranslations(lang: Language) {
    const copyBtn = document.querySelector('.copy-btn') as HTMLButtonElement;
    if (copyBtn) {
      const textSpan = copyBtn.querySelector('.copy-text') as HTMLSpanElement;
      if (textSpan) {
        const currentText = textSpan.textContent?.trim();
        if (currentText === 'Copy Email' || currentText === 'Copied!' || currentText === 'Copiar Email' || currentText === '¡Copiado!') {
          textSpan.textContent = getTranslation('copyEmail', lang);
        }
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const copyBtn = document.querySelector(".copy-btn");

    copyBtn?.addEventListener("click", async () => {
      const email = copyBtn.getAttribute("data-email");
      if (email) {
        try {
          await navigator.clipboard.writeText(email);

          const lang = (localStorage.getItem('language') as Language) || 'en';
          const textSpan = copyBtn.querySelector('.copy-text') as HTMLSpanElement;
          const originalSvg = copyBtn.querySelector('svg')?.cloneNode(true);

          if (textSpan) {
            textSpan.textContent = getTranslation('copied', lang);
          }
          // Swap checkmark icon
          const svg = copyBtn.querySelector('svg');
          if (svg) {
            svg.innerHTML = '<polyline points="20,6 9,17 4,12"></polyline>';
          }

          setTimeout(() => {
            if (textSpan) {
              textSpan.textContent = getTranslation('copyEmail', lang);
            }
            const svg2 = copyBtn.querySelector('svg');
            if (svg2 && originalSvg) {
              svg2.innerHTML = (originalSvg as SVGElement).innerHTML;
            }
          }, 2000);
        } catch (err) {
          console.error("Failed to copy email:", err);
        }
      }
    });
  });

  window.addEventListener('languagechange', ((e: Event) => {
    const customEvent = e as CustomEvent;
    updateContactTranslations(customEvent.detail.language);
  }) as EventListener);

  const savedLanguage = (localStorage.getItem('language') as Language) || 'en';
  updateContactTranslations(savedLanguage);
</script>
