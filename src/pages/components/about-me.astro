---
---

<section class="about-section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-wrapper">
        <div class="about-image-container">
          <img
            src="/images/memoji.png"
            alt="Cristian Teijeiro"
            class="about-image"
            loading="lazy"
          />
          <div class="image-glow"></div>
        </div>
        <div class="image-badges">
          <div class="image-badge">
            <span class="badge-dot"></span>
            <span data-i18="about.status">Open to work</span>
          </div>
        </div>
      </div>

      <div class="about-content">
        <div class="section-header">
          <div class="section-badge">
            <span class="badge-text" data-i18="about.badge">About Me</span>
          </div>
          <h2 class="section-title" data-i18="about.title">
            Building <span class="gradient-text">digital solutions</span> with a
            builder mindset
          </h2>
        </div>

        <p class="about-text" data-i18="about.p1">
          I'm a Software Engineering student at URJC (last year) who loves
          turning ideas into real products. From AI-powered platforms to
          full-stack web apps, I enjoy the entire process of building something
          that works.
        </p>

        <p class="about-text" data-i18="about.p2">
          Currently diving into React Native & Expo with Orial, a personal habit
          tracker, and finishing my TFG (Smashly) — a padel app with AI
          features. I'm passionate about AI integration, clean architecture, and
          building tools that people actually use.
        </p>

        <div class="about-details">
          <div class="detail-item">
            <h4 data-i18="about.education">Education</h4>
            <p>Software Engineering — URJC (2021-2025)</p>
          </div>
          <div class="detail-item">
            <h4 data-i18="about.location">Location</h4>
            <p>Madrid, Spain</p>
          </div>
          <div class="detail-item">
            <h4 data-i18="about.languages">Languages</h4>
            <p>Spanish (native) & English (professional)</p>
          </div>
        </div>

        <div class="skills-section">
          <h3 class="skills-title" data-i18="about.skillsTitle">Tech Stack</h3>
          <div class="skills-grid">
            <span class="skill-tag">React</span>
            <span class="skill-tag">TypeScript</span>
            <span class="skill-tag">Node.js</span>
            <span class="skill-tag">Python</span>
            <span class="skill-tag">React Native</span>
            <span class="skill-tag">Expo</span>
            <span class="skill-tag">Next.js</span>
            <span class="skill-tag">PostgreSQL</span>
            <span class="skill-tag">Supabase</span>
            <span class="skill-tag">Tailwind</span>
            <span class="skill-tag">Drizzle ORM</span>
            <span class="skill-tag">AI Integration</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .about-section {
    padding: var(--space-2xl) 0;
    background: var(--secondary);
    position: relative;
    overflow: hidden;
  }

  .about-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .about-image-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .about-image-container {
    position: relative;
    width: 280px;
    height: 280px;
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    border: 4px solid var(--border);
    position: relative;
    z-index: 2;
    background: var(--card-bg);
  }

  .image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    background: var(--accent-gradient);
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(30px);
    z-index: 1;
    animation: glow 3s ease-in-out infinite alternate;
  }

  @keyframes glow {
    from { opacity: 0.1; }
    to { opacity: 0.25; }
  }

  .image-badges {
    display: flex;
    gap: var(--space-sm);
  }

  .image-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(220, 38, 38, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 9999px;
    font-size: 0.875rem;
    color: var(--accent-light);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .section-header {
    margin-bottom: var(--space-xs);
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(220, 38, 38, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 9999px;
    margin-bottom: var(--space-md);
  }

  .badge-text {
    font-size: 0.875rem;
    color: var(--accent-light);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-text {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
  }

  .about-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .detail-item h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent-light);
    margin: 0 0 var(--space-xs) 0;
    font-weight: 600;
  }

  .detail-item p {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin: 0;
    font-weight: 500;
  }

  .skills-section {
    margin-top: var(--space-md);
  }

  .skills-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent-light);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .skill-tag {
    padding: 6px 14px;
    background: rgba(220, 38, 38, 0.08);
    color: var(--accent-light);
    border: 1px solid rgba(220, 38, 38, 0.15);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .skill-tag:hover {
    background: rgba(220, 38, 38, 0.15);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    .about-grid {
      gap: var(--space-xl);
    }

    .about-image-container {
      width: 240px;
      height: 240px;
    }

    .image-glow {
      width: 260px;
      height: 260px;
    }
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-content {
      align-items: center;
    }

    .about-text {
      max-width: 100%;
    }

    .about-details {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
      text-align: center;
    }

    .skills-grid {
      justify-content: center;
    }

    .about-image-container {
      width: 200px;
      height: 200px;
    }

    .image-glow {
      width: 220px;
      height: 220px;
    }

    .section-badge {
      margin: 0 auto var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .about-section {
      padding: var(--space-xl) 0;
    }

    .about-image-container {
      width: 160px;
      height: 160px;
    }

    .image-glow {
      width: 180px;
      height: 180px;
    }

    .skill-tag {
      font-size: 0.75rem;
      padding: 4px 10px;
    }

    .about-text {
      font-size: 0.9rem;
    }
  }
</style>
