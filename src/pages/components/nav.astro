---
---

<header class="navbar" id="navbar">
  <div class="nav-container">
    <a href="/" class="logo-link">
      <img src="/images/logo.svg" alt="Cristian Teijeiro" class="logo-image" />
    </a>

    <nav class="nav-menu" id="nav-menu">
      <a href="#about" class="nav-link" data-i18="nav.about"
        >About</a
      >
      <a href="#experience" class="nav-link" data-i18="nav.experience"
        >Experience</a
      >
      <a href="#projects" class="nav-link" data-i18="nav.projects">Projects</a>
      <a href="#contact" class="nav-link" data-i18="nav.contact">Contact</a>
    </nav>

    <div class="nav-actions">
      <!-- Language Toggle - Text-based segmented control -->
      <div class="lang-toggle" id="language-toggle">
        <button class="lang-btn" data-lang="es" aria-label="Español">
          <span class="lang-text">ES</span>
        </button>
        <button class="lang-btn active" data-lang="en" aria-label="English">
          <span class="lang-text">EN</span>
        </button>
      </div>

      <!-- Theme Toggle -->
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg
          class="sun-icon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="moon-icon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <button
        class="mobile-menu-toggle"
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div class="mobile-panel" id="mobile-panel">
    <nav class="mobile-nav">
      <a href="#about" class="mobile-link" data-i18="nav.about">About</a>
      <a href="#experience" class="mobile-link" data-i18="nav.experience">Experience</a>
      <a href="#projects" class="mobile-link" data-i18="nav.projects">Projects</a>
      <a href="#contact" class="mobile-link" data-i18="nav.contact">Contact</a>
    </nav>
    <div class="mobile-footer">
      <div class="lang-toggle" id="mobile-lang-toggle">
        <button class="lang-btn" data-lang="es" aria-label="Español">
          <span class="lang-text">ES</span>
        </button>
        <button class="lang-btn active" data-lang="en" aria-label="English">
          <span class="lang-text">EN</span>
        </button>
      </div>
      <button class="theme-toggle" id="mobile-theme-toggle" aria-label="Toggle theme">
        <svg class="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<style is:global>
  /* ── Navbar Base ── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border-bottom: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    animation: navReveal 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes navReveal {
    from {
      opacity: 0;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .navbar.scrolled {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(28px) saturate(1.6);
    -webkit-backdrop-filter: blur(28px) saturate(1.6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .light .navbar {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border-bottom: 1px solid transparent;
  }

  .light .navbar.scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(28px) saturate(1.6);
    -webkit-backdrop-filter: blur(28px) saturate(1.6);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  /* ── Container ── */
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  /* ── Logo ── */
  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.15rem;
    transition: opacity 0.25s ease;
    flex-shrink: 0;
  }

  .logo-link:hover {
    opacity: 0.75;
  }

  .logo-image {
    width: 30px;
    height: 30px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo-link:hover .logo-image {
    transform: scale(1.1);
  }

  .light .logo-image {
    filter: invert(1) brightness(0) saturate(100%);
  }

  /* ── Desktop Nav Links ── */
  .nav-menu {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 450;
    font-size: 0.925rem;
    letter-spacing: 0.02em;
    padding: 0.25rem 0;
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1), left 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    transform: translateZ(0);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
    left: 0;
  }

  /* ── Nav Actions (desktop) ── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Pill Toggle Base ── */
  .lang-toggle {
    display: flex;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    overflow: hidden;
    padding: 2px;
    gap: 2px;
  }

  .light .lang-toggle {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .lang-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .lang-btn:hover {
    color: var(--text-primary);
  }

  .lang-btn.active {
    background: var(--accent);
    color: #ffffff;
    box-shadow: 0 1px 4px rgba(220, 38, 38, 0.3);
  }

  .lang-btn.active:hover {
    color: #ffffff;
  }

  /* ── Theme Toggle ── */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
  }

  .light .theme-toggle {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .theme-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }

  .light .theme-toggle:hover {
    background: rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.15);
  }

  .theme-toggle .sun-icon,
  .theme-toggle .moon-icon {
    transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .theme-toggle:hover .sun-icon,
  .theme-toggle:hover .moon-icon {
    transform: scale(1.15);
  }

  .dark .theme-toggle .sun-icon { display: none; }
  .dark .theme-toggle .moon-icon { display: block; }
  .light .theme-toggle .sun-icon { display: block; }
  .light .theme-toggle .moon-icon { display: none; }

  /* ── Mobile Menu Toggle ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 8px 7px;
    flex-shrink: 0;
  }

  .light .mobile-menu-toggle {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .mobile-menu-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .light .mobile-menu-toggle:hover {
    background: rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.15);
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background: var(--accent);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: translateX(-8px);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background: var(--accent);
  }

  /* ── Mobile Panel ── */
  .mobile-panel {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    flex-direction: column;
    padding: 2rem 1.5rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 99;
    overflow-y: auto;
  }

  .light .mobile-panel {
    background: rgba(255, 255, 255, 0.98);
  }

  .mobile-panel.active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    justify-content: center;
    align-items: center;
  }

  .mobile-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    padding: 0.75rem 0;
    transition: color 0.3s ease, transform 0.3s ease;
    position: relative;
  }

  .mobile-link::after {
    content: "";
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-link:hover {
    color: var(--text-primary);
  }

  .mobile-link:hover::after {
    width: 100%;
  }

  .mobile-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .light .mobile-footer {
    border-top-color: rgba(0, 0, 0, 0.08);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .nav-container {
      padding: 0 1rem;
      height: 64px;
    }

    .nav-menu {
      display: none;
    }

    .nav-actions .lang-toggle {
      display: none;
    }

    .nav-actions .theme-toggle {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .mobile-panel {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-panel {
      display: none !important;
    }
  }

  @media (max-width: 480px) {
    .nav-container {
      padding: 0 0.75rem;
      height: 58px;
    }

    .mobile-panel {
      top: 58px;
    }

    .mobile-link {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  import {
    translations,
    type Language,
  } from "../../i18n/translations";

  translations["en"];

  function getNestedValue(obj: any, path: string): string {
    return path.split(".").reduce((acc, part) => acc && acc[part], obj);
  }

  function updatePageTranslations(lang: Language) {
    const elements = document.querySelectorAll("[data-i18]");
    elements.forEach((el) => {
      const key = el.getAttribute("data-i18");
      if (key) {
        const text = getNestedValue(translations[lang], key);
        if (text) el.textContent = text;
      }
    });
  }

  // ── Language Toggle ──
  const langToggles = document.querySelectorAll(".lang-toggle");
  let currentLanguage: Language = "en";

  function setLanguage(lang: Language) {
    currentLanguage = lang;
    localStorage.setItem("language", lang);

    langToggles.forEach((toggle) => {
      toggle.querySelectorAll(".lang-btn").forEach((btn) => {
        btn.classList.toggle("active", btn.getAttribute("data-lang") === lang);
      });
    });

    updatePageTranslations(lang);
    document.documentElement.lang = lang;

    window.dispatchEvent(
      new CustomEvent("languagechange", { detail: { language: lang } })
    );
  }

  langToggles.forEach((toggle) => {
    toggle.querySelectorAll(".lang-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const lang = btn.getAttribute("data-lang") as Language;
        setLanguage(lang);
      });
    });
  });

  const savedLanguage = localStorage.getItem("language") as Language | null;
  setLanguage(savedLanguage || "en");

  // ── Theme Toggle ──
  const themeToggles = document.querySelectorAll(".theme-toggle");

  function updateTheme(theme: string) {
    document.documentElement.classList.remove("light", "dark");
    document.documentElement.classList.add(theme);
    localStorage.setItem("theme", theme);
  }

  themeToggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const currentTheme = document.documentElement.classList.contains("dark")
        ? "dark"
        : "light";
      updateTheme(currentTheme === "dark" ? "light" : "dark");
    });
  });

  // ── Scroll Effect ──
  const navbar = document.getElementById("navbar");
  let ticking = false;

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        navbar?.classList.toggle("scrolled", window.scrollY > 40);
        ticking = false;
      });
      ticking = true;
    }
  });

  // ── Mobile Menu ──
  const mobileToggle = document.getElementById("mobile-menu-toggle");
  const mobilePanel = document.getElementById("mobile-panel");
  let menuOpen = false;

  function toggleMenu() {
    menuOpen = !menuOpen;
    mobileToggle?.classList.toggle("active", menuOpen);
    mobilePanel?.classList.toggle("active", menuOpen);
    document.body.style.overflow = menuOpen ? "hidden" : "";
  }

  function closeMenu() {
    if (menuOpen) toggleMenu();
  }

  mobileToggle?.addEventListener("click", toggleMenu);

  // Close on link click
  mobilePanel?.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });

  // ── Sync language changes from other components ──
  window.addEventListener("languagechange", ((e: Event) => {
    const customEvent = e as CustomEvent;
    setLanguage(customEvent.detail.language);
  }) as EventListener);
</script>
