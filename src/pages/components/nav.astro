    <nav class="mobile-nav">
      <a href="#projects" class="mobile-link" data-i18="nav.projects">Projects</a>
      <a href="#work" class="mobile-link" data-i18="nav.work">Work</a>
      <a href="#contact" class="mobile-link" data-i18="nav.contact">Contact</a>
    </nav>
    <div class="mobile-footer">
      <div class="lang-toggle" id="mobile-lang-toggle">
        <button class="lang-btn" data-lang="es" aria-label="Español">
          <span class="lang-text">ES</span>
        </button>
        <button class="lang-btn active" data-lang="en" aria-label="English">
          <span class="lang-text">EN</span>
        </button>
      </div>
      <button class="theme-toggle" id="mobile-theme-toggle" aria-label="Toggle theme">
        <svg class="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="12" y1="2" x2="12" y2="4"></line>
          <line x1="12" y1="20" x2="12" y2="22"></line>
          <line x1="4.93" y1="4.93" x2="6.05" y2="6.05"></line>
          <line x1="17.95" y1="17.95" x2="19.07" y2="19.07"></line>
          <line x1="2" y1="12" x2="4" y2="12"></line>
          <line x1="20" y1="12" x2="22" y2="12"></line>
          <line x1="4.93" y1="19.07" x2="6.05" y2="17.95"></line>
          <line x1="17.95" y1="6.05" x2="19.07" y2="4.93"></line>
        </svg>
        <svg class="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
