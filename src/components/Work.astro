---
const roles = [
  {
    id: "fusuma",
    org: "Fusuma",
    logo: "/images/fusuma.jpg",
    logoWide: false,
    when: "Jun 2026 — Now",
    tagKey: "tagCurrent",
    tagClass: "now",
    bullets: 2,
  },
  {
    id: "pwc",
    org: "PwC",
    logo: "/images/pwc.png",
    logoWide: true,
    when: "Oct 2025 — Feb 2026",
    tagKey: "tagIntern",
    tagClass: "",
    bullets: 2,
  },
  {
    id: "apple",
    org: "Apple",
    logo: "/images/apple.png",
    logoWide: false,
    when: "Jul 2025 — Jan 2026",
    tagKey: "tagRetail",
    tagClass: "",
    bullets: 1,
  },
  {
    id: "futsal",
    org: "CE Futsal Pardillo",
    logo: "/images/ce_futsal_pardillo.png",
    logoWide: false,
    when: "Sep 2022 — Jun 2025",
    tagKey: "tagCoach",
    tagClass: "",
    bullets: 1,
  },
];
---

<section class="section" id="work">
  <div class="container">
    <header class="section-head reveal">
      <div>
        <span class="kicker"><span class="num">03</span> · <span data-i18="work.kicker">Work</span></span>
        <h2 class="h2 title" style="margin-top: 8px;" data-i18="work.title">Recent history.</h2>
      </div>
      <span class="meta">2022 → <span data-i18="work.now">Now</span></span>
    </header>

    <div class="work-list">
      {roles.map((r) => (
        <article class="work-row reveal" data-od-id={`role-${r.id}`}>
          <div class="when">
            {r.tagClass === "now" && <span class="live" aria-hidden="true"></span>}
            {r.when}
          </div>
          <div>
            <h3>
              <span data-i18={`work.roles.${r.id}.title`}>Role</span>
              <span class="org">
                — <img class:list={["org-logo", { wide: r.logoWide }]} src={r.logo} alt={r.org} />{r.org}
              </span>
            </h3>
            <ul class="bullets">
              <li data-i18={`work.roles.${r.id}.b1`}>—</li>
              {r.bullets > 1 && <li data-i18={`work.roles.${r.id}.b2`}>—</li>}
            </ul>
          </div>
          <span class={`tag ${r.tagClass}`} data-i18={`work.${r.tagKey}`}>Tag</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work-list { display: flex; flex-direction: column; }
  .work-row {
    display: grid; grid-template-columns: 110px 1fr auto;
    gap: 24px; align-items: baseline;
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }
  .work-row:last-child { border-bottom: 1px solid var(--border); }
  .work-row .when { font-family: var(--font-mono); font-size: 12px; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; }
  .work-row .when .live { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); margin-right: 6px; vertical-align: middle; }
  .work-row h3 { font-size: 18px; font-weight: 600; display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .work-row h3 .org { color: var(--muted); font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
  .org-logo {
    width: 22px; height: 22px;
    padding: 3px;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    object-fit: contain;
    flex: none;
  }
  .org-logo.wide { width: 30px; }
  .work-row .bullets { margin: 6px 0 0; padding-left: 18px; color: var(--muted); font-size: 14px; line-height: 1.5; }
  .work-row .bullets li::marker { color: var(--accent); }
  .work-row .bullets li { margin-bottom: 2px; }
  .work-row .bullets li:last-child { margin-bottom: 0; }
  .work-row .tag {
    display: inline-flex; align-items: center;
    padding: 3px 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .work-row .tag.now { color: var(--accent); border-color: var(--accent); }
  @media (max-width: 720px) {
    .work-row { grid-template-columns: 1fr; gap: 8px; }
    .work-row .tag { justify-self: start; }
  }
</style>
